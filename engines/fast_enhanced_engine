#!/usr/bin/env python3
"""
Fast Enhanced Homemade Chess Engine - Loads only essential opening books
This version loads only the most important books for faster startup.
"""

import sys
import os

# Add the engines directory to the Python path
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

# Import and run the enhanced engine with fast loading
from homemade_engine import EnhancedUCIEngine
import threading
import time

class FastEnhancedUCIEngine(EnhancedUCIEngine):
    """Fast version that loads only essential opening books"""
    
    def __init__(self):
        # Initialize without opening books first
        self.board = None
        self.evaluator = None
        self.search_engine = None
        self.search_thread = None
        self.running = True
        
        # Initialize basic components
        import chess
        from nnue import HybridEvaluator
        from parallel_search import IterativeDeepeningParallel
        
        self.board = chess.Board()
        self.evaluator = HybridEvaluator()
        self.search_engine = IterativeDeepeningParallel(self.evaluator, num_threads=4)
        
        # Load only essential books in background
        self.polyglot_book = None
        self.opening_book = None
        self._load_books_async()
        
        # UCI options
        self.options = {
            "Hash": {"type": "spin", "default": 128, "min": 1, "max": 2048},
            "Depth": {"type": "spin", "default": 8, "min": 1, "max": 25},
            "Time": {"type": "spin", "default": 3000, "min": 100, "max": 60000},
            "Threads": {"type": "spin", "default": 4, "min": 1, "max": 16},
            "UseNNUE": {"type": "check", "default": True},
            "UseParallel": {"type": "check", "default": True},
        }
        
        # Current settings
        self.hash_size = 128
        self.max_depth = 8
        self.time_limit = 3000
        self.num_threads = 4
        self.use_nnue = True
        self.use_parallel = True
    
    def _load_books_async(self):
        """Load opening books in background thread"""
        def load_books():
            try:
                from polyglot_book import MultiBook
                from opening_book import EnhancedOpeningBook
                
                # Load only the most essential books
                books_dir = os.path.join(os.path.dirname(os.path.dirname(__file__)), "books")
                essential_books = [
                    "DefaultBook.bin", "Book.bin", "main.bin", "perfect_book.bin"
                ]
                
                book_paths = []
                for book_name in essential_books:
                    book_path = os.path.join(books_dir, book_name)
                    if os.path.exists(book_path):
                        book_paths.append(book_path)
                
                if book_paths:
                    self.polyglot_book = MultiBook(book_paths)
                    self.opening_book = EnhancedOpeningBook(book_paths)
                    print(f"Loaded {len(book_paths)} essential opening books")
                else:
                    print("No opening books found")
                    
            except Exception as e:
                print(f"Failed to load opening books: {e}")
        
        # Start loading in background
        threading.Thread(target=load_books, daemon=True).start()
    
    def _get_opening_move(self):
        """Get opening move with fallback if books not loaded yet"""
        # Try Polyglot books if loaded
        if self.polyglot_book:
            move = self.polyglot_book.get_best_move(self.board)
            if move and self.board.is_legal(move):
                return move
        
        # Try enhanced opening book if loaded
        if self.opening_book:
            move = self.opening_book.get_move(self.board)
            if move and self.board.is_legal(move):
                return move
        
        # Fallback to simple opening moves
        if len(self.board.move_stack) < 3:
            opening_moves = ["e2e4", "d2d4", "g1f3", "c2c4", "b1c3", "f2f4", "g2g3", "b2b3"]
            legal_moves = [move.uci() for move in self.board.legal_moves]
            available_openings = [move for move in opening_moves if move in legal_moves]
            
            if available_openings:
                import random
                return chess.Move.from_uci(random.choice(available_openings))
        
        return None

def main():
    """Main entry point"""
    engine = FastEnhancedUCIEngine()
    engine.run()

if __name__ == "__main__":
    main()