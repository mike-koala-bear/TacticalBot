#!/usr/bin/env python3
"""
Simple Enhanced Engine - No opening books for fast testing
"""

import sys
import os

# Add the engines directory to the Python path
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

# Import and run the enhanced engine without opening books
from homemade_engine import EnhancedUCIEngine
import chess
import random

class SimpleEnhancedUCIEngine(EnhancedUCIEngine):
    """Simple version without opening books for fast testing"""
    
    def __init__(self):
        # Initialize without opening books
        self.board = chess.Board()
        self.evaluator = None
        self.search_engine = None
        self.search_thread = None
        self.running = True
        
        # Initialize basic components
        from nnue import HybridEvaluator
        from parallel_search import IterativeDeepeningParallel
        
        self.evaluator = HybridEvaluator()
        self.search_engine = IterativeDeepeningParallel(self.evaluator, num_threads=4)
        
        # No opening books for fast startup
        self.polyglot_book = None
        self.opening_book = None
        
        # UCI options
        self.options = {
            "Hash": {"type": "spin", "default": 128, "min": 1, "max": 2048},
            "Depth": {"type": "spin", "default": 8, "min": 1, "max": 25},
            "Time": {"type": "spin", "default": 3000, "min": 100, "max": 60000},
            "Threads": {"type": "spin", "default": 4, "min": 1, "max": 16},
            "UseNNUE": {"type": "check", "default": True},
            "UseParallel": {"type": "check", "default": True},
        }
        
        # Current settings
        self.hash_size = 128
        self.max_depth = 8
        self.time_limit = 3000
        self.num_threads = 4
        self.use_nnue = True
        self.use_parallel = True
    
    def _get_opening_move(self):
        """Simple opening move selection without books"""
        # Simple opening moves for first 3 moves
        if len(self.board.move_stack) < 3:
            opening_moves = ["e2e4", "d2d4", "g1f3", "c2c4", "b1c3", "f2f4", "g2g3", "b2b3"]
            legal_moves = [move.uci() for move in self.board.legal_moves]
            available_openings = [move for move in opening_moves if move in legal_moves]
            
            if available_openings:
                return chess.Move.from_uci(random.choice(available_openings))
        
        return None

def main():
    """Main entry point"""
    engine = SimpleEnhancedUCIEngine()
    engine.run()

if __name__ == "__main__":
    main()